// --- Wrapper (Main_graph, encode/decode schemes) ---
//-*-c-*-
//=============================================================================
// Wrapper so the common rtlib harness can run the generated bootstrap_full
// kernel. The generated bootstrap_full.c provides bootstrap_full(),
// Get_context_params(), and Get_rt_data_info(); this file provides
// Main_graph(), Get_encode_scheme(), Get_decode_scheme(), Get_input_count(),
// Get_output_count() — matching the native compiler's dataset .inc pattern.
//=============================================================================

#include "rt_ant/rt_ant.h"

extern CIPHERTEXT bootstrap_full(CIPHERTEXT p0, CIPHERTEXT p1);

// The rtlib is compiled as C, so these functions need C linkage when
// compiled in a C++ translation unit (g++ -std=gnu++17).
#ifdef __cplusplus
extern "C" {
#endif

DATA_SCHEME* Get_encode_scheme(int idx) {
  static MAP_DESC desc_0[] = {{NORMAL, 0, 0, 0, 0}};
  static MAP_DESC desc_1[] = {{NORMAL, 0, 0, 0, 0}};
  static DATA_SCHEME scheme_0 = {
    "p0", {0, 0, 0, 0}, 1, desc_0
  };
  static DATA_SCHEME scheme_1 = {
    "p1", {0, 0, 0, 0}, 1, desc_1
  };
  static DATA_SCHEME* scheme[] = { &scheme_0, &scheme_1 };
  return scheme[idx];
}

DATA_SCHEME* Get_decode_scheme(int idx) {
  static MAP_DESC desc[] = {{NORMAL, 0, 0, 0, 0}};
  static DATA_SCHEME scheme = {
    "output", {0, 0, 0, 0}, 1, desc
  };
  return &scheme;
}

int Get_input_count() {
  return 2;
}

int Get_output_count() {
  return 1;
}

bool Main_graph() {
  CIPHERTEXT input0;
  CIPHERTEXT input1;
  CIPHERTEXT result;
  input0 = Get_input_data("p0", 0);
  input1 = Get_input_data("p1", 0);
  memset(&result, 0, sizeof(result));
  result = bootstrap_full(input0, input1);
  Set_output_data("output", 0, &result);
  return true;
}

